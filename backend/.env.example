PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/dailyzo
JWT_SECRET=replace_me_with_long_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string
JWT_REFRESH_EXPIRES_IN=30d
CLIENT_URL=http://localhost:5173

# Razorpay (optional — leave blank to use mock payment flow)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Default admin (created by seed script)
ADMIN_EMAIL=admin@dailyzo.com
ADMIN_PASSWORD=admin@123
ADMIN_NAME=Super Admin
